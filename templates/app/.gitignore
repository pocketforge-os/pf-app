# build + sim + packaging artifacts. dist/ holds the OCI (addressed by digest — NEVER
# committed), the signed siblings, and dev signing keys; all regenerated by oci/build-oci.sh.
/build/
/.cache/
/evidence/
/dist/
*.o
*.arm64
# stray signing material (belt-and-suspenders; keys normally live under dist/keys/)
*.key
!*.pub
