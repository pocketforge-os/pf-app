# syntax=docker/dockerfile:1
# Dockerfile.pack — hermetic packaging toolchain for the PocketForge app packaging path.
#
# One pinned image carries every tool the path needs (mmdebstrap, umoci, cosign, syft,
# grype, minisign, qemu-user-static) so packaging is reproducible off ANY docker host and
# never depends on what happens to be installed there. Versions/sha256 come from pins-pack.env
# (passed as build-args). NEVER apt/pip inside a running app container — the recipe lives here.
FROM debian:bookworm-slim

ARG MMDEBSTRAP_VER
ARG MINISIGN_VER
ARG UMOCI_VER
ARG UMOCI_SHA256
ARG COSIGN_VER
ARG COSIGN_SHA256
ARG SYFT_VER
ARG SYFT_SHA256
ARG GRYPE_VER
ARG GRYPE_SHA256

ENV DEBIAN_FRONTEND=noninteractive
RUN set -eux; \
    apt-get update -qq; \
    apt-get install -y --no-install-recommends \
        mmdebstrap="${MMDEBSTRAP_VER}" \
        minisign="${MINISIGN_VER}" \
        qemu-user-static \
        arch-test \
        binfmt-support \
        fakeroot \
        mount \
        uidmap \
        ca-certificates \
        curl \
        jq \
        xz-utils \
        zstd \
        apt-utils \
        dpkg-dev \
        coreutils; \
    rm -rf /var/lib/apt/lists/*

# --- pinned static binaries, sha256-verified ---------------------------------
RUN set -eux; \
    fetch() { url="$1"; sha="$2"; out="$3"; \
        curl -fsSL "$url" -o "$out"; \
        echo "${sha}  ${out}" | sha256sum -c -; }; \
    fetch "https://github.com/opencontainers/umoci/releases/download/${UMOCI_VER}/umoci.linux.amd64" \
          "${UMOCI_SHA256}" /usr/local/bin/umoci; \
    chmod +x /usr/local/bin/umoci; \
    fetch "https://github.com/sigstore/cosign/releases/download/${COSIGN_VER}/cosign-linux-amd64" \
          "${COSIGN_SHA256}" /usr/local/bin/cosign; \
    chmod +x /usr/local/bin/cosign; \
    fetch "https://github.com/anchore/syft/releases/download/${SYFT_VER}/syft_${SYFT_VER#v}_linux_amd64.tar.gz" \
          "${SYFT_SHA256}" /tmp/syft.tgz; \
    tar -C /usr/local/bin -xzf /tmp/syft.tgz syft; \
    fetch "https://github.com/anchore/grype/releases/download/${GRYPE_VER}/grype_${GRYPE_VER#v}_linux_amd64.tar.gz" \
          "${GRYPE_SHA256}" /tmp/grype.tgz; \
    tar -C /usr/local/bin -xzf /tmp/grype.tgz grype; \
    rm -f /tmp/syft.tgz /tmp/grype.tgz; \
    umoci --version; cosign version 2>/dev/null | head -1 || true; \
    syft version | head -1; grype version | head -1; minisign -v || true; \
    mmdebstrap --version | head -1

WORKDIR /pack
