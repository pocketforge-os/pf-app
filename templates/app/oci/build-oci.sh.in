#!/usr/bin/env bash
# oci/build-oci.sh — the app-packaging harness STUB (scaffolded by pf-app).
#
# STATUS: STUB. This is the authoring-side seam that the E8 packaging path
# (tsp-ziac.3) fills in. It assembles the parts an author already owns — the built
# binary, the launch shim, the validated app.toml — into a staging bundle, and marks
# EXACTLY where each packaging + signing + SBOM + scan step plugs in. It intentionally
# does NOT sign or push: those steps need the packaging path's keys + toolchain.
#
# The target pipeline (tsp-ziac.3; build-integration-reference.md §18):
#   mmdebstrap -> tar -> OCI image -> cosign sign-by-digest -> syft SBOM -> grype scan
# and the SIBLING FILES that ride alongside app.toml in the installed bundle:
#   app.toml            the descriptor (this app)
#   app.toml.sig        minisign detached signature over app.toml         [.3]
#   oci/                the OCI image layout (rootfs + config)             [.3]
#   oci.sig             cosign signature over the OCI image BY DIGEST      [.3]
#   sbom.spdx.json      syft SBOM of the bundle                           [.3]
#   slice.conf          systemd resource limits for the app slice         [.3]
#
# Usage:
#   ./oci/build-oci.sh [--out dist]
set -euo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
cd "$HERE"

OUT="dist"
while [ "$#" -gt 0 ]; do
    case "$1" in
        --out) OUT="$2"; shift 2 ;;
        -h|--help) sed -n '2,30p' "$0"; exit 0 ;;
        *) echo "build-oci: unknown arg $1" >&2; exit 2 ;;
    esac
done

BIN="build/{{APP_SLUG}}.arm64"
if [ ! -f "$BIN" ]; then
    echo "build-oci: $BIN not found — run ./build.sh first" >&2
    exit 1
fi

STAGE="$OUT/stage"
rm -rf "$STAGE"
mkdir -p "$STAGE"

# ---- assemble the app payload the packaging path will wrap ---------------------
cp "$BIN"      "$STAGE/{{APP_SLUG}}.arm64"
cp launch      "$STAGE/launch"
cp app.toml    "$STAGE/app.toml"
chmod +x "$STAGE/launch" "$STAGE/{{APP_SLUG}}.arm64"
echo "build-oci: staged app payload -> $STAGE"
ls -l "$STAGE"

cat <<'NOTE'

build-oci: STUB complete — payload staged, NOT packaged/signed.
The following steps are handed to the E8 packaging path (tsp-ziac.3):

  [ ] validate   : pf app-validate app.toml            (platform static validator)
  [ ] rootfs     : mmdebstrap --variant=apt ... -> tar (minimal app rootfs)
  [ ] oci        : oci/ image layout (rootfs + config)
  [ ] sign       : minisign app.toml -> app.toml.sig ; cosign sign OCI BY DIGEST -> oci.sig
  [ ] sbom       : syft <bundle> -o spdx-json > sbom.spdx.json
  [ ] scan       : grype sbom:sbom.spdx.json (fail on the policy threshold)
  [ ] slice      : emit slice.conf (systemd resource limits)

See oci/build-oci.sh header + platform/docs/PLATFORM-ABI-CONTRACT.md §6.
NOTE
