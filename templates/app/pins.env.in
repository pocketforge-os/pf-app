# {{APP_NAME}} — pinned refs for the reproducible build (scaffolded by pf-app).
#
# Every external source pulled by build.sh resolves through this file (committed, so a
# rebuild months later is byte-for-byte the same as today). Update pins on their own PR
# with a short rationale. These defaults are the pf-hwprobe-proven set that builds + runs
# green under the E5 sim; bump deliberately.

# E2 runtime (libpocketforge C ABI). ABI frozen v1 (runtime/STABILITY.md).
RUNTIME_REPO=https://github.com/pocketforge-os/runtime.git
RUNTIME_COMMIT=0fedcdbadbcc0415687ed4861b163e3f36320ef3
RUNTIME_REF=origin/main

# E5 simulator + its bundled SDL3 render build (feeds the sim harness + the arm64 SDL3.a).
SIM_REPO=https://github.com/pocketforge-os/sim.git
SIM_COMMIT=7d0c3c9fc6e80fd7792c99cc6a77b564b24fdc7e
SIM_REF=origin/main

# E1 platform descriptors (read-only consumer; the a133/a523 capabilities.toml the sim stages).
PLATFORM_REPO=https://github.com/pocketforge-os/platform.git
PLATFORM_COMMIT=82a95655d906a6cb7c6b63c94e4e3797a03c3d34
PLATFORM_REF=origin/main

# Toolchain image (Rust + gcc-aarch64 cross). rust>=1.85 for the runtime dep graph
# (indexmap 2.14+ pulls edition2024).
RUST_IMAGE=rust:1.85-bookworm
