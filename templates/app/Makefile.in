# {{APP_NAME}} — thin cross-build Makefile (scaffolded by pf-app).
#
# The heavy lifting (Rust cross-build of libpocketforge.a, cloning the pinned sim for
# SDL3) lives in build.sh; this Makefile is a pure C compile step, driven by build.sh
# with the header/lib paths + arch already resolved. Run `./build.sh` (not make directly).

# --- INPUTS (all overridable from build.sh) ------------------------------------
CC             ?= aarch64-linux-gnu-gcc
STRIP          ?= aarch64-linux-gnu-strip

SDL3_INCLUDE   ?= /opt/pf/sdl3-render/arm64/include
PF_INCLUDE     ?= /opt/pf/runtime/include

SDL3_STATIC    ?= /opt/pf/sdl3-render/arm64/lib/libSDL3.a
PF_STATIC      ?= /opt/pf/libpocketforge.a

OUT_DIR        ?= build
BIN_NAME       ?= {{APP_SLUG}}

# --- FLAGS ---------------------------------------------------------------------
# -ffp-contract=off matches the sim's app builds (native==qemu float bits identical).
# -static gives a self-contained ELF the harness runs over any bookworm-arm64 rootfs;
# SDL3_DYNAMIC_API still engages, so the `launch` shim's SDL_DYNAMIC_API env swaps in
# libSDL3-pocketforge.so.0 on-device.
CFLAGS         ?= -O2 -Wall -Wextra -Wpedantic -std=gnu11 -ffp-contract=off
CFLAGS         += -I$(SDL3_INCLUDE) -I$(PF_INCLUDE) -Isrc
LDFLAGS        ?= -static
LIBS           ?= $(SDL3_STATIC) $(PF_STATIC) -lm -ldl -lpthread -lrt

SRC            := src/main.c
BIN            := $(OUT_DIR)/$(BIN_NAME)

.PHONY: all clean help
all: $(BIN)

$(BIN): $(SRC) | $(OUT_DIR)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $(SRC) $(LIBS)
	@file $@ || true

$(OUT_DIR):
	mkdir -p $(OUT_DIR)

clean:
	rm -rf $(OUT_DIR)

help:
	@echo "{{APP_NAME}} cross-build (call via ./build.sh; this Makefile is not user-facing)."
	@echo "Overridable: CC STRIP SDL3_INCLUDE PF_INCLUDE SDL3_STATIC PF_STATIC OUT_DIR BIN_NAME"
